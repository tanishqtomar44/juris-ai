# ============================================================
#  Juris.AI — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git.
# ============================================================

# Google Gemini API (free tier)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ChromaDB (local by default)
CHROMA_PERSIST_DIR=./knowledge_base/chroma_db

# AES-256 secret for server-side decryption
AES_SECRET_KEY=your_32_char_secret_key_here_1234

# Google Calendar API
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_FILE=./calendar/credentials.json

# Environment
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
